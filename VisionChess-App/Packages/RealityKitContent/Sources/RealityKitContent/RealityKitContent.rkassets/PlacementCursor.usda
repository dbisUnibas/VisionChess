#usda 1.0
(
    defaultPrim = ""
    metersPerUnit = 1
    upAxis = "Y"
)

def Cube "Cube" (
    active = true
    prepend apiSchemas = ["MaterialBindingAPI"]
)
{
    rel material:binding = </Cube/DefaultMaterial> (
        bindMaterialAs = "weakerThanDescendants"
    )
    double size = 0.01
    quatf xformOp:orient = (1, 0, 0, 0)
    float3 xformOp:scale = (39, 3.05, 39)
    float3 xformOp:translate = (0, 0, 0)
    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

    def Material "DefaultMaterial"
    {
        token outputs:mtlx:surface
        token outputs:realitykit:vertex
        token outputs:surface.connect = </Cube/DefaultMaterial/DefaultSurfaceShader.outputs:surface>

        def Shader "DefaultSurfaceShader"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1, 0.9116913, 0.4687597) (
                colorSpace = "srgb_displayp3"
            )
            color3f inputs:emissiveColor = (1, 0.8416893, 0.37393147) (
                colorSpace = "srgb_displayp3"
            )
            float inputs:opacity = 0.4
            float inputs:roughness = 0.75
            token outputs:surface
        }
    }

    def RealityKitComponent "Collider"
    {
        uint group = 1
        uniform token info:id = "RealityKit.Collider"
        uint mask = 4294967295
        token type = "Default"

        def RealityKitStruct "Shape"
        {
            float3 extent = (0.39, 0.0305, 0.39)
            token shapeType = "Box"

            def RealityKitStruct "pose"
            {
            }
        }
    }

    def RealityKitComponent "InputTarget"
    {
        uniform token info:id = "RealityKit.InputTarget"
    }
}

