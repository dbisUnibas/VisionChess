    def Cube "Cube" (
        active = true
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Transform/Cube/DefaultMaterial>
        double size = 0.01
        float3 xformOp:scale = (32, 1, 32)
        float3 xformOp:translate = (0, -0.0099, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

        def Material "DefaultMaterial"
        {
            prepend token outputs:surface.connect = </Transform/Cube/DefaultMaterial/DefaultSurfaceShader.outputs:surface>

